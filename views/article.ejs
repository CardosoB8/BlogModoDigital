<%- include('partials/header') %>

<main class="container mx-auto px-5 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2">
            <%- breadcrumbs %>
            
            <article class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 md:p-8">
                <h1 class="text-3xl md:text-4xl font-bold mb-4"><%= article.title %></h1>
                
                <div class="flex items-center gap-4 mb-6 text-sm text-gray-500">
                    <span><i class="far fa-user mr-1"></i><%= article.author %></span>
                    <span><i class="far fa-calendar-alt mr-1"></i><%= new Date(article.createdAt).toLocaleDateString('pt-BR') %></span>
                    <span><i class="far fa-eye mr-1"></i><%= article.views %> visualizações</span>
                </div>
                
                <% if (article.coverImage) { %>
                    <img src="<%= article.coverImage %>" alt="<%= article.coverAlt %>" class="w-full rounded-xl mb-8">
                <% } %>
                
                <div class="prose-custom max-w-none">
                    <%- article.content %>
                </div>
                
                <!-- Tags -->
                <% if (article.tags && JSON.parse(article.tags).length) { %>
                    <div class="flex flex-wrap gap-2 mt-8 pt-6 border-t border-gray-200 dark:border-gray-700">
                        <% JSON.parse(article.tags).forEach(tag => { %>
                            <span class="px-3 py-1 bg-gray-100 dark:bg-gray-700 rounded-full text-sm">#<%= tag %></span>
                        <% }) %>
                    </div>
                <% } %>
                
                <!-- Share Buttons -->
                <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
                    <h3 class="text-lg font-semibold mb-3">Compartilhe este artigo</h3>
                    <div class="flex gap-3">
                        <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(siteConfig.siteUrl + '/artigo/' + article.slug) %>" target="_blank" class="bg-blue-600 text-white p-2 rounded-full w-10 h-10 flex items-center justify-center hover:bg-blue-700 transition">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(siteConfig.siteUrl + '/artigo/' + article.slug) %>&text=<%= encodeURIComponent(article.title) %>" target="_blank" class="bg-sky-500 text-white p-2 rounded-full w-10 h-10 flex items-center justify-center hover:bg-sky-600 transition">
                            <i class="fab fa-twitter"></i>
                        </a>
                        <a href="https://wa.me/?text=<%= encodeURIComponent(article.title + ' - ' + siteConfig.siteUrl + '/artigo/' + article.slug) %>" target="_blank" class="bg-green-500 text-white p-2 rounded-full w-10 h-10 flex items-center justify-center hover:bg-green-600 transition">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                    </div>
                </div>
            </article>
        </div>
        
        <!-- Sidebar -->
        <div class="space-y-6">
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-5">
                <h3 class="text-xl font-bold mb-4">Artigos Relacionados</h3>
                <div class="space-y-4">
                    <% related.forEach(rel => { %>
                        <a href="/artigo/<%= rel.slug %>" class="flex gap-3 hover:bg-gray-50 dark:hover:bg-gray-700 p-2 rounded-lg transition">
                            <img src="<%= rel.coverImage %>" class="w-16 h-16 object-cover rounded-lg">
                            <div>
                                <h4 class="font-semibold hover:text-blue-600"><%= rel.title %></h4>
                                <p class="text-xs text-gray-500"><%= new Date(rel.createdAt).toLocaleDateString('pt-BR') %></p>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>
            
            <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-xl p-5 text-white text-center">
                <i class="fas fa-envelope text-3xl mb-2"></i>
                <h3 class="text-xl font-bold mb-2">Newsletter</h3>
                <p class="text-sm mb-3">Receba novos artigos no seu email</p>
                <input type="email" placeholder="Seu email" class="w-full p-2 rounded-lg text-gray-900 mb-2">
                <button class="bg-white text-blue-600 px-4 py-2 rounded-lg font-semibold hover:bg-gray-100 transition w-full">
                    Assinar
                </button>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>