<%- include('partials/header') %>

<main class="container mx-auto px-5 lg:px-8 py-8">
    <!-- Hero Section -->
    <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-8 mb-12 text-white">
        <h1 class="text-3xl md:text-4xl font-bold mb-3"><%= siteConfig.title %></h1>
        <p class="text-lg opacity-90"><%= siteConfig.description %></p>
    </div>
    
    <!-- Search Bar -->
    <div class="mb-8">
        <form action="/buscar" method="GET" class="max-w-2xl mx-auto">
            <div class="flex gap-2">
                <input type="text" name="q" placeholder="Buscar artigos..." value="<%= search || '' %>" 
                    class="flex-1 p-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 rounded-xl transition">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>
    </div>
    
    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-8">
        <a href="/" class="px-4 py-2 rounded-full <%= !category ? 'bg-blue-600 text-white' : 'bg-gray-200 dark:bg-gray-700 hover:bg-blue-100' %> transition">
            Todos
        </a>
        <a href="/?categoria=Tecnologia" class="px-4 py-2 rounded-full <%= category === 'Tecnologia' ? 'bg-blue-600 text-white' : 'bg-gray-200 dark:bg-gray-700 hover:bg-blue-100' %> transition">
            Tecnologia
        </a>
        <a href="/?categoria=Marketing" class="px-4 py-2 rounded-full <%= category === 'Marketing' ? 'bg-blue-600 text-white' : 'bg-gray-200 dark:bg-gray-700 hover:bg-blue-100' %> transition">
            Marketing
        </a>
        <a href="/?categoria=Produtividade" class="px-4 py-2 rounded-full <%= category === 'Produtividade' ? 'bg-blue-600 text-white' : 'bg-gray-200 dark:bg-gray-700 hover:bg-blue-100' %> transition">
            Produtividade
        </a>
    </div>
    
    <!-- Articles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% articles.forEach(article => { %>
            <article class="bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all group">
                <a href="/artigo/<%= article.slug %>">
                    <img src="<%= article.coverImage %>" alt="<%= article.coverAlt %>" class="w-full h-48 object-cover group-hover:scale-105 transition duration-300">
                </a>
                <div class="p-5">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-xs bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 px-2 py-1 rounded-full">
                            <%= article.category %>
                        </span>
                        <span class="text-xs text-gray-500"><i class="far fa-calendar-alt mr-1"></i><%= new Date(article.createdAt).toLocaleDateString('pt-BR') %></span>
                    </div>
                    <h2 class="text-xl font-bold mb-2 hover:text-blue-600 transition">
                        <a href="/artigo/<%= article.slug %>"><%= article.title %></a>
                    </h2>
                    <p class="text-gray-600 dark:text-gray-300 text-sm mb-3 line-clamp-3"><%= article.excerpt %></p>
                    <div class="flex justify-between items-center pt-3 border-t border-gray-100 dark:border-gray-700">
                        <span class="text-xs text-gray-500"><i class="far fa-user mr-1"></i><%= article.author %></span>
                        <a href="/artigo/<%= article.slug %>" class="text-blue-600 text-sm font-medium hover:underline">Leia mais <i class="fas fa-arrow-right text-xs"></i></a>
                    </div>
                </div>
            </article>
        <% }) %>
    </div>
    
    <!-- Pagination -->
    <% if (totalPages > 1) { %>
        <div class="flex justify-center gap-2 mt-10">
            <% for (let i = 1; i <= totalPages; i++) { %>
                <a href="?page=<%= i %><%= category ? '&categoria=' + category : '' %><%= search ? '&q=' + search : '' %>" 
                    class="px-4 py-2 rounded-lg <%= currentPage === i ? 'bg-blue-600 text-white' : 'bg-gray-200 dark:bg-gray-700 hover:bg-blue-100' %> transition">
                    <%= i %>
                </a>
            <% } %>
        </div>
    <% } %>
</main>

<%- include('partials/footer') %>